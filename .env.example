# CMMC Compass — Environment Configuration
# Copy this file to .env and fill in your values

# ─── Application ──────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=8080

# ─── Database ─────────────────────────────────────────────────────────────────
# PostgreSQL connection string
DATABASE_URL=postgresql://username:password@localhost:5432/cmmc_compass

# ─── Session ──────────────────────────────────────────────────────────────────
# Generate a strong random string: openssl rand -base64 32
SESSION_SECRET=your-session-secret-here

# ─── File Storage ─────────────────────────────────────────────────────────────
# Object storage for evidence files and exported documents
STORAGE_BUCKET=cmmc-compass-evidence
STORAGE_REGION=us-east-1
STORAGE_ACCESS_KEY=your-access-key
STORAGE_SECRET_KEY=your-secret-key

# ─── Email (for notifications and POA&M reminders) ────────────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=notifications@cmmccompass.io
SMTP_PASS=your-smtp-password
EMAIL_FROM=CMMC Compass <notifications@cmmccompass.io>

# ─── Frontend ─────────────────────────────────────────────────────────────────
VITE_API_URL=http://localhost:8080
